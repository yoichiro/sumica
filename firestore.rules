rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/generations/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/rankingRollups/{hash} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
