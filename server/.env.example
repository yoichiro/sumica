# Copy this file to server/.env and edit as needed.
# Every setting has a code-level default, so a missing .env still works —
# override here only when your local ports differ or you need custom CORS.

# Port the Express server listens on.
PORT=5000

# LM Studio's OpenAI-compatible Local Server endpoint.
LM_STUDIO_URL=http://localhost:1234

# Stable Diffusion Web UI (AUTOMATIC1111 / Forge) API endpoint. Must be started with --api.
STABLE_DIFFUSION_URL=http://localhost:7860

# Which LM Studio model to use. Leave empty to use whichever model is currently loaded.
LM_STUDIO_MODEL=

# Comma-separated list of allowed CORS origins for the frontend.
# If unset, the Vite dev origins (localhost:5173 / 127.0.0.1:5173) are allowed.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
