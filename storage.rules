rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/images/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Sidecar 256px WebP thumbnails uploaded alongside the PNG in the
    // client-side generation flow. Same auth model as the images path.
    match /users/{uid}/thumbs/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
